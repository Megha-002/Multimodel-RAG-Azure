
# LLM — Groq

GROQ_API_KEY=your_groq_key
GROQ_LLM_MODEL=llama-3.1-8b-instant
GROQ_WHISPER_MODEL=whisper-large-v3-turbo


# EMBEDDINGS — Hugging Face

HF_API_KEY=your_hf_token
HF_EMBED_URL=https://api-inference.huggingface.co/pipeline/feature-extraction/sentence-transformers/all-MiniLM-L6-v2


# VECTOR DB — Pinecone

PINECONE_API_KEY=your_pinecone_key
PINECONE_INDEX=rag-index
PINECONE_REGION=us-east-1


# EXPERIMENT TRACKING — DagsHub + MLflow

DAGSHUB_USERNAME=your_username
DAGSHUB_REPO=Multimodel-RAG-Azure
DAGSHUB_TOKEN=your_dagshub_token
MLFLOW_TRACKING_URI=https://dagshub.com/your_username/Multimodel-RAG-Azure.mlflow


# MONITORING — Grafana Cloud + Prometheus

GRAFANA_REMOTE_WRITE_URL=https://prometheus-prod-xx.grafana.net/api/prom/push
GRAFANA_PROM_USERNAME=123456
GRAFANA_PROM_API_KEY=your_grafana_api_key


# UI → API

API_BASE_URL=http://localhost:8000


# RAG CONFIG

TOP_K=5
CHUNK_SIZE=500
CHUNK_OVERLAP=50